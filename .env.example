# ============================================================
# maya-mcp — Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# .env is git-ignored and never committed.
# ============================================================

# ── Vision3D GPU server ───────────────────────────────────────
# Vision3D runs as a standalone server on the GPU machine.
# See the vision3d repo for setup: https://github.com/abrahamADSK/vision3d
#
# GPU_API_URL  — base URL of the Vision3D server (HTTP, direct)
# GPU_API_KEY  — API key (leave empty for open access on LAN)

GPU_API_URL=http://your-gpu-host:8000
GPU_API_KEY=                              # leave empty if open access on LAN

# ── Local project ────────────────────────────────────────────
# Absolute path to this repository on your local machine
PROJECT_DIR=/path/to/maya-mcp

# Output subdirectory within reference/3d_output/ (default: 0)
# OUTPUT_SUBDIR=0

# Default reference image (override with --image flag)
# REFERENCE_IMAGE=/path/to/my_reference.jpg

# ── Maya MCP server (core/) ─────────────────────────────────
# MAYA_HOST=localhost
# MAYA_PORT=7001
