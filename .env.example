# ============================================================
# maya-mcp — Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# .env is git-ignored and never committed.
# ============================================================

# ── Remote GPU server ───────────────────────────────────────
# SSH connection to the Linux machine with the GPU
GPU_SSH_HOST=user@gpu-host          # e.g. john@192.168.1.50  or  john@myserver.local
GPU_SSH_KEY=~/.ssh/id_rsa           # path to your private SSH key (no passphrase, or use ssh-agent)

# Directories on the remote GPU server
GPU_REMOTE_BASE=/opt/ai-studio      # root of the ai-studio installation
GPU_VENV=/opt/ai-studio/vision/.venv
GPU_MODELS_DIR=/opt/ai-studio/vision/hf_models   # where Hunyuan3D-2 weights are stored

# ── Local project ────────────────────────────────────────────
# Absolute path to this repository on your local machine
PROJECT_DIR=/path/to/maya-mcp

# Output subdirectory within reference/3d_output/ (default: 0)
# OUTPUT_SUBDIR=0

# Default reference image (override with --image flag)
# REFERENCE_IMAGE=/path/to/my_reference.jpg

# ── Pipeline timeouts (seconds) ─────────────────────────────
# SHAPE_TIMEOUT=900     # 15 min — shape generation (longer on first run while weights load)
# TEXTURE_TIMEOUT=600   # 10 min — texture generation

# ── Maya MCP server (core/) ─────────────────────────────────
# MAYA_HOST=localhost
# MAYA_PORT=7001
