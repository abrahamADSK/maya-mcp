# ============================================================
# maya-mcp — Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# .env is git-ignored and never committed.
# ============================================================

# ── Remote GPU server (HTTPS API) ─────────────────────────────
# The GPU server runs a FastAPI service (gpu_server.py) behind
# Caddy (HTTPS reverse proxy). See vision/setup_gpu_server.sh.
#
# GPU_API_URL  — base URL of the GPU API server
# GPU_API_KEY  — API key generated during setup (see vision/.api_key on GPU box)

GPU_API_URL=https://your-gpu-host:9443   # HTTPS via Caddy (or http://your-gpu-host:8000 for direct)
GPU_API_KEY=your-api-key-here            # from setup_gpu_server.sh output

# Set to "true" if using a valid TLS cert (e.g. Let's Encrypt).
# Set to "false" for self-signed certs (default for LAN).
# GPU_VERIFY_TLS=false

# ── Legacy SSH mode (deprecated) ──────────────────────────────
# If you haven't migrated to the HTTPS API yet, you can still
# use SSH. Set GPU_API_URL="" to disable API mode and fall back
# to SSH. See README.md for SSH setup instructions.
#
# GPU_SSH_HOST=my-gpu               # SSH alias from ~/.ssh/config
# GPU_REMOTE_BASE=/home/your-user/ai-studio
# GPU_VENV=/home/your-user/ai-studio/vision/.venv
# GPU_VISION_DIR=/home/your-user/ai-studio/vision
# GPU_WORK_DIR=/home/your-user/ai-studio/reference/3d_output

# ── Local project ────────────────────────────────────────────
# Absolute path to this repository on your local machine
PROJECT_DIR=/path/to/maya-mcp

# Output subdirectory within reference/3d_output/ (default: 0)
# OUTPUT_SUBDIR=0

# Default reference image (override with --image flag)
# REFERENCE_IMAGE=/path/to/my_reference.jpg

# ── Maya MCP server (core/) ─────────────────────────────────
# MAYA_HOST=localhost
# MAYA_PORT=7001
